		<!-- Dragging -->
		
		<Action Name="Pinched" Type="Embedded" Class="com.group_finity.mascot.action.Dragged">
			<Animation Condition="#{FootX &lt; mascot.environment.cursor.x-50}">
				<Pose Image="/pinch_l3.png" ImageAnchor="64,128" Velocity="0,0" Duration="5" />
			</Animation>
			<Animation Condition="#{FootX &lt; mascot.environment.cursor.x-30}">
				<Pose Image="/pinch_l2.png" ImageAnchor="64,128" Velocity="0,0" Duration="5" />
			</Animation>
			<Animation Condition="#{FootX &lt; mascot.environment.cursor.x}">
				<Pose Image="/pinch_l1.png" ImageAnchor="64,128" Velocity="0,0" Duration="5" />
			</Animation>
			<Animation Condition="#{FootX &gt; mascot.environment.cursor.x-10 &amp;&amp; FootX &lt; mascot.environment.cursor.x+10}">
				<Pose Image="/pinch_default.png" ImageAnchor="64,128" Velocity="0,0" Duration="5" />
			</Animation>
			<Animation Condition="#{FootX &lt; mascot.environment.cursor.x+30}">
				<Pose Image="/pinch_r1.png" ImageAnchor="64,128" Velocity="0,0" Duration="5"/>
			</Animation>
			<Animation Condition="#{FootX &lt; mascot.environment.cursor.x+50}">
				<Pose Image="/pinch_r2.png" ImageAnchor="64,128" Velocity="0,0" Duration="5" />
			</Animation>
			<Animation Condition="#{FootX &gt;= mascot.environment.cursor.x+30}">
				<Pose Image="/pinch_r3.png" ImageAnchor="64,128" Velocity="0,0" Duration="5" />
			</Animation>
		</Action>
		
